{
    "name": "jmbg-labs/jmbg",
    "description": "Validate Serbian unique master citizen number (JMBG - Jedinstveni Matični Broj Građana)",
    "type": "library",
    "keywords": [
        "jmbg",
        "serbia",
        "validation",
        "identifier",
        "national-id",
        "citizen-number",
        "validator"
    ],
    "homepage": "https://github.com/jmbg-labs/php",
    "license": "MIT",
    "authors": [
        {
            "name": "Dušan Veličković",
            "email": "dusanvelickovic003@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0|^12.0|^13.0"
    },
    "autoload": {
        "psr-4": {
            "JmbgLabs\\Jmbg\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JmbgLabs\\Jmbg\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage"
    },
    "support": {
        "issues": "https://github.com/jmbg-labs/php/issues",
        "source": "https://github.com/jmbg-labs/php"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
